# Database (reads - direct MySQL/MariaDB connection)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dolibarr
DB_USER=dolibarr
DB_PASS=secret
DB_PREFIX=llx_

# Dolibarr REST API (writes - preserves business logic)
DOLIBARR_API_URL=https://erp.example.com/api/index.php
DOLIBARR_API_KEY=your_api_key_here

# MCP Server
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8080
MCP_AUTH_TOKEN=your_secret_token_here

# Dolibarr instance
DOLIBARR_ENTITY=1
